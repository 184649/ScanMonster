{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldawn.example/design/character-ip-v2/species-motif.schema.json",
  "title": "WORLDAWN SpeciesMotif design document",
  "description": "Non-production proposal separating biological motifs from IP characters.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sampleOnly", "motifs"],
  "properties": {
    "schemaVersion": { "const": "2.0.0-proposal" },
    "sampleOnly": { "const": true },
    "motifs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/speciesMotif" }
    }
  },
  "$defs": {
    "legacySource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["legacyCharacterId", "masterPath", "world", "masterNo"],
      "properties": {
        "legacyCharacterId": { "type": "string", "minLength": 1 },
        "masterPath": { "const": "assets/characters/character_master.json" },
        "world": { "enum": ["ground", "waterside", "sky", "bug", "phantom", "planet"] },
        "masterNo": { "type": "integer", "minimum": 1 }
      }
    },
    "speciesMotif": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "motifId", "nameJa", "nameEn", "taxonomy", "worldCandidates", "reality",
        "observedRarity", "bodyFeatures", "behaviors", "usableShapeElements",
        "usableColorElements", "legacyCatalogIds", "legacySources"
      ],
      "properties": {
        "motifId": { "type": "string", "pattern": "^motif_species_[a-z0-9]+(?:_[a-z0-9]+)*$" },
        "nameJa": { "type": "string", "minLength": 1 },
        "nameEn": { "type": "string", "minLength": 1 },
        "taxonomy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["class", "group"],
          "properties": {
            "class": { "type": "string", "minLength": 1 },
            "group": { "type": "string", "minLength": 1 }
          }
        },
        "worldCandidates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["ground", "waterside", "sky", "bug", "phantom", "planet"] }
        },
        "reality": { "enum": ["extant", "extinct", "legendary", "fictional", "uncertain"] },
        "observedRarity": { "enum": ["normal", "rare", "legendary", "secret"] },
        "bodyFeatures": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "behaviors": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "usableShapeElements": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "usableColorElements": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "legacyCatalogIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "legacySources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/legacySource" } },
        "notes": { "type": "string" }
      }
    }
  }
}
