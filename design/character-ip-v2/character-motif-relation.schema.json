{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldawn.example/design/character-ip-v2/character-motif-relation.schema.json",
  "title": "WORLDAWN CharacterMotifRelation design document",
  "description": "Each set has exactly one primary relation and at most three relations; primary-count and weight-sum are semantic validation rules.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sampleOnly", "relationSets"],
  "properties": {
    "schemaVersion": { "const": "2.0.0-proposal" },
    "sampleOnly": { "const": true },
    "relationSets": {
      "type": "array",
      "items": { "$ref": "#/$defs/relationSet" }
    }
  },
  "$defs": {
    "relationSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["characterId", "relations"],
      "properties": {
        "characterId": { "type": "string", "pattern": "^(prototype_character|wdchar)_[a-z0-9]+(?:_[a-z0-9]+)*$" },
        "relations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/relation" }
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["motifId", "role", "weight", "notes"],
      "properties": {
        "motifId": { "type": "string", "pattern": "^motif_(species|behavior|nature)_[a-z0-9]+(?:_[a-z0-9]+)*$" },
        "role": { "enum": ["primary", "secondary", "behavior", "surface", "color", "silhouette"] },
        "weight": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "notes": { "type": "string", "minLength": 1 }
      }
    }
  }
}
