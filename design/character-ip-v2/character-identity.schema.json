{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldawn.example/design/character-ip-v2/character-identity.schema.json",
  "title": "WORLDAWN CharacterIdentity design document",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sampleOnly", "characters"],
  "properties": {
    "schemaVersion": { "const": "2.0.0-proposal" },
    "sampleOnly": { "const": true },
    "characters": {
      "type": "array",
      "items": { "$ref": "#/$defs/characterIdentity" }
    }
  },
  "$defs": {
    "characterIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "characterId", "internalCodename", "displayNameJa", "displayNameEn", "nameStatus",
        "world", "rarity", "releaseStatus", "personality", "behavior", "visualHook",
        "silhouetteHook", "bodyArchitecture", "faceLanguage", "colorLanguage",
        "toyeticStructure", "artStatus", "assetVersion", "isFlagship",
        "isPlayableReleaseCandidate", "createdAt", "updatedAt"
      ],
      "properties": {
        "characterId": { "type": "string", "pattern": "^(prototype_character|wdchar)_[a-z0-9]+(?:_[a-z0-9]+)*$" },
        "internalCodename": { "type": "string", "minLength": 1 },
        "displayNameJa": { "type": ["string", "null"] },
        "displayNameEn": { "type": ["string", "null"] },
        "nameStatus": { "enum": ["working", "approved"] },
        "world": { "enum": ["ground", "waterside", "sky", "bug", "phantom", "planet"] },
        "rarity": { "enum": ["normal", "rare", "legendary", "secret"] },
        "releaseStatus": { "enum": ["prototype", "candidate", "future", "inactive", "approved"] },
        "personality": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "type": "string", "minLength": 1 } },
        "behavior": { "type": "string", "minLength": 1 },
        "visualHook": { "type": "string", "minLength": 1 },
        "silhouetteHook": { "type": "string", "minLength": 1 },
        "bodyArchitecture": { "type": "string", "minLength": 1 },
        "faceLanguage": { "type": "string", "minLength": 1 },
        "colorLanguage": { "type": "string", "minLength": 1 },
        "toyeticStructure": {
          "type": "object",
          "additionalProperties": false,
          "required": ["majorBlockCount", "description"],
          "properties": {
            "majorBlockCount": { "type": "integer", "minimum": 3, "maximum": 9 },
            "description": { "type": "string", "minLength": 1 }
          }
        },
        "artStatus": { "enum": ["brief", "silhouette", "face", "color", "model_sheet", "production", "rejected"] },
        "assetVersion": { "type": "string", "pattern": "^v[0-9]+$" },
        "isFlagship": { "type": "boolean" },
        "isPlayableReleaseCandidate": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
