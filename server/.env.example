NODE_ENV=production
PORT=3000

# PostgreSQL 接続文字列（docker-compose ではサービス名 db を使う）
DATABASE_URL=postgresql://worldawn_user:change_me@localhost:5432/worldawn

# CORS 許可オリジン（アプリ配信元）。開発は * でも可、本番は明示する。
APP_ORIGIN=https://app.example.com
API_BASE_URL=https://api.example.com

# 認証・ハッシュ用シークレット（本番で必ず変更）
JWT_SECRET=change_me
SOURCE_HASH_SECRET=change_me
