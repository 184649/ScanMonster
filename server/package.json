{
  "name": "worldawn-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "WORLDAWN API server: official discovery numbering, scan transaction, PostgreSQL.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test \"tests/**/*.test.ts\"",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "it:postgres": "bash scripts/it-postgres.sh",
    "server:dev": "tsx watch src/server.ts",
    "server:start": "tsx src/server.ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "pg-mem": "^3.0.5",
    "tsx": "^4.16.0",
    "typescript": "^5.9.2"
  }
}
